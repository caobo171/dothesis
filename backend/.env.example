PORT=8001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/margin
REDIS_URL=redis://localhost:6379

JWT_SECRET=your-jwt-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# AWS SES
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
SES_FROM_EMAIL=noreply@margin.app

# ── Payments (Polar + PayPal + Paddle, matches survify env names) ─────────
# Frontend origin used to build return/cancel URLs.
CLIENT_URL=http://localhost:8002

# PayPal — production
PAYPAL_CLIENT_ID=
PAYPAL_SECRET_KEY=
# PayPal — sandbox (used when NODE_ENV !== 'production')
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_SECRET_KEY=

# Polar.sh — set POLAR_MODE=production to switch off sandbox
POLAR_ACCESS_TOKEN=
POLAR_MODE=sandbox
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=

# Paddle — webhook signing secret from the Paddle dashboard
PADDLE_NOTIFICATION_SECRET=

# Copyscape
COPYSCAPE_USERNAME=
COPYSCAPE_API_KEY=

# Semantic Scholar (optional, for higher rate)
SEMANTIC_SCHOLAR_API_KEY=

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:8002
